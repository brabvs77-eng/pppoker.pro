# Cloudflare Pages response headers (copied to apps/web/out on build).
# https://developers.cloudflare.com/pages/configuration/headers/

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/webp
