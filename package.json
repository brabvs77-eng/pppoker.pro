{
  "name": "pppoker-pro",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "extract:content": "node scripts/extract-content.mjs",
    "analyze:styles": "node scripts/analyze-stylesheets.mjs",
    "prepare:public": "node scripts/prepare-next-public.mjs",
    "build:legacy-react": "node scripts/build-react-static-site.mjs",
    "verify:legacy-react": "node scripts/verify-react-static-site.mjs",
    "build:next": "npm run extract:content && npm run prepare:public && npm --prefix apps/web run build",
    "build": "npm run build:next",
    "dev": "npm run extract:content && npm run prepare:public && npm --prefix apps/web run dev",
    "verify:next": "node scripts/verify-next-site.mjs",
    "migrate:react": "npm run build:legacy-react && npm run verify:legacy-react"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "glob": "^13.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5"
  }
}
